{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["custom/cpu-temp", "cpu", "custom/cpu-watt", "custom/gpu", "custom/gpu-watt", "memory", "disk", "network", "tray"],

    "sway/workspaces": {
        "format": "{name}",
        "disable-scroll": true
    },

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },

    "clock": {
        "format": "{:%Y-%m-%d %H:%M:%S}",
        "interval": 1
    },

    "cpu": {
        "format": "CPU {usage}%",
        "interval": 2
    },

    "custom/cpu-temp": {
        "exec": "sensors | awk '/^Core 0:/ {gsub(/[^0-9.]/, \"\", $3); printf \"%.0f°F\", $3 * 9/5 + 32}'",
        "interval": 5,
        "format": "{}"
    },

    "custom/cpu-watt": {
        "exec": "E1=$(cat /sys/class/powercap/intel-rapl:0/energy_uj); sleep 0.5; E2=$(cat /sys/class/powercap/intel-rapl:0/energy_uj); echo $(( (E2 - E1) / 500000 ))W",
        "interval": 5,
        "format": "{}"
    },

    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu,temperature.gpu --format=csv,noheader,nounits | awk -F', ' '{printf \"GPU %s%% %d°F\", $1, $2 * 9/5 + 32}'",
        "interval": 5,
        "format": "{}"
    },

    "custom/gpu-watt": {
        "exec": "nvidia-smi --query-gpu=power.draw --format=csv,noheader,nounits | awk '{printf \"%.0fW\", $1}'",
        "interval": 5,
        "format": "{}"
    },

    "memory": {
        "format": "RAM {used:0.1f}G/{total:0.1f}G",
        "interval": 2
    },

    "disk": {
        "format": "DISK {free}",
        "path": "/"
    },

    "network": {
        "interface": "eno1",
        "format-ethernet": "IP {ipaddr}",
        "format-disconnected": "IP --"
    },

    "tray": {
        "spacing": 10
    }
}
