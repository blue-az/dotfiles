# Fedora Desktop - Multi-monitor setup
# Copy to outputs.conf on this machine

# Display configuration
output DP-1 disable
output DP-3 pos 0 390 res 1680x1050
output DP-2 pos 1680 0 res 2560x1440

# Workspace assignments
workspace 1 output DP-2
workspace 2 output DP-3
workspace 3 output DP-1
workspace 4 output DP-1

# Screen layout shortcuts
bindsym $mod+F2 exec ~/.screenlayout/sway-2s.sh
bindsym $mod+F3 exec ~/.screenlayout/sway-3s.sh
