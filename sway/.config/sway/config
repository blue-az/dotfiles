# Sway config (based on i3 config)
# Mod key (Mod1=Alt, Mod4=Super/Windows key)
set $mod Mod4

# Font for window titles
font pango:monospace 8

# ============ NVIDIA WORKAROUNDS ============
# Uncomment if you have cursor issues:
# seat seat0 xcursor_theme default 24

# ============ INPUT CONFIGURATION ============
# Swap Caps Lock and Super keys (replaces xmodmap)
input type:keyboard {
    xkb_file /home/blueaz/.config/xkb/keymap
}

# Touchpad settings
input type:touchpad {
    tap enabled
    dwt enabled
}

# ============ OUTPUTS ============
# Machine-specific output config (not in git)
# Templates in config.d/outputs.conf.*
include ~/.config/sway/config.d/outputs.conf

# Wallpaper (replaces feh)
output * bg ~/.dotfiles/wallpaper/FedoraDark.jpg fill

# ============ SCREEN LOCK ============
# Lock screen manually
bindsym $mod+Escape exec swaylock -f -c 000000

# Auto-lock after 5 min idle, turn off displays after 5.5 min
exec swayidle -w \
    timeout 300 'swaylock -f -c 000000' \
    timeout 330 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f -c 000000'

# ============ STARTUP ============
# Export environment to systemd for portals (file dialogs, etc.)
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

# Notification daemon
exec dunst

# Start on workspaces 1 and 2
exec swaymsg 'workspace 2; workspace 1'

# ============ KEYBINDINGS ============
# Start a terminal (foot on laptop, terminator on desktop)
set $term_cmd sh -c 'if grep -q "ROG Flow Z13" /sys/class/dmi/id/product_name 2>/dev/null; then foot; else terminator; fi'
bindsym $mod+Return exec $term_cmd

# Kill focused window
bindsym $mod+Shift+q kill

# Start launcher (native Wayland)
bindsym $mod+d exec wmenu-run

# Launch Firefox
bindsym $mod+Shift+f exec firefox

# Cycle through audio sources
bindsym $mod+Mod1+F11 exec ~/.config/i3/scripts/cycle-audio-source.sh

# Cycle keyboard backlight mode
bindsym $mod+F11 exec asusctl -n
bindsym $mod+Mod1+F2 exec ~/.config/i3/scripts/cycle-video-audio.sh

# Change focus (vim-style)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Split orientation
bindsym $mod+backslash split h
bindsym $mod+minus split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Toggle tiling / floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Focus parent
bindsym $mod+a focus parent

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Workspace-to-output assignments are in config.d/outputs.conf

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Reload/exit
bindsym $mod+Shift+c exec google-chrome
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Yes' 'swaymsg exit'

# Resize mode
mode "resize" {
    bindsym h resize shrink width 10 px
    bindsym j resize grow height 10 px
    bindsym k resize shrink height 10 px
    bindsym l resize grow width 10 px

    bindsym Left resize shrink width 10 px
    bindsym Down resize grow height 10 px
    bindsym Up resize shrink height 10 px
    bindsym Right resize grow width 10 px

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# ============ SCREENSHOTS ============
# Full screen to file
bindsym Print exec grim ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png

# Select region to file
bindsym Shift+Print exec grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png

# Full screen to clipboard
bindsym Ctrl+Print exec grim - | wl-copy

# Select region to clipboard
bindsym Ctrl+Shift+Print exec grim -g "$(slurp)" - | wl-copy

# ============ VOLUME ============
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle

# ============ BRIGHTNESS (DDC/CI for external monitors) ============
# Disabled - DDC/CI is slow and triggers waybar whiteout issue
# Only monitor 2 (AL2216W) responds; monitor 1 (XB271HU) ignores brightness via DDC
# Script available: ~/.config/i3/scripts/brightness-ddc.sh up|down
bindsym $mod+F1 exec ~/.config/i3/scripts/brightness-ddc.sh down
bindsym $mod+F2 exec ~/.config/i3/scripts/brightness-ddc.sh up

# ============ VIRTUAL DISPLAY (for Deskreen extend) ============
# Create virtual output for Chromebook as second monitor
bindsym $mod+F7 exec swaymsg create_output && swaymsg output HEADLESS-1 enable resolution 1920x1080 position 1280 0
# Destroy virtual output
bindsym $mod+Shift+F7 exec swaymsg output HEADLESS-1 disable

# Status bar (waybar)
exec_always sh -c 'pkill -x waybar || true; sleep 0.5; waybar'

# Network Manager applet (for tray)
exec nm-applet --indicator

# System overlay (replaces conky)
exec_always ~/.config/waybar/start-overlay.sh
