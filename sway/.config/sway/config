# Sway config (based on i3 config)
# Mod key (Mod1=Alt, Mod4=Super/Windows key)
set $mod Mod4

# Font for window titles
font pango:monospace 8

# ============ NVIDIA WORKAROUNDS ============
# Uncomment if you have cursor issues:
# seat seat0 xcursor_theme default 24

# ============ INPUT CONFIGURATION ============
# Swap Caps Lock and Super keys (replaces xmodmap)
input type:keyboard {
    xkb_file /home/blueaz/.config/xkb/keymap
}

# Touchpad settings
input type:touchpad {
    tap enabled
    dwt enabled
}

# ============ OUTPUTS ============
# Output names may differ from X11 - run 'swaymsg -t get_outputs' to check
# Commenting out for now - let Sway auto-detect
# output DP-2 pos 0 0
# output DP-5 pos 2560 0

# Wallpaper (replaces feh)
output * bg ~/.dotfiles/wallpaper/FedoraDark.jpg fill

# ============ SCREEN LOCK ============
# Lock screen manually
bindsym $mod+Escape exec swaylock -f -c 000000

# Auto-lock after 5 min idle, turn off displays after 5.5 min
exec swayidle -w \
    timeout 300 'swaylock -f -c 000000' \
    timeout 330 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f -c 000000'

# ============ STARTUP ============
# Notification daemon
exec dunst

# Start on workspaces 1 and 2
exec swaymsg 'workspace 2; workspace 1'

# ============ KEYBINDINGS ============
# Start a terminal
bindsym $mod+Return exec terminator

# Kill focused window
bindsym $mod+Shift+q kill

# Start launcher (dmenu works via XWayland, or use wmenu/wofi)
bindsym $mod+d exec dmenu_run

# Cycle through audio sources
bindsym $mod+Mod1+F11 exec ~/.config/i3/scripts/cycle-audio-source.sh
bindsym $mod+Mod1+F2 exec ~/.config/i3/scripts/cycle-video-audio.sh

# Change focus (vim-style)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Split orientation
bindsym $mod+backslash split h
bindsym $mod+minus split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Toggle tiling / floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Focus parent
bindsym $mod+a focus parent

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Assign workspaces to outputs
workspace $ws1 output DP-2
workspace $ws2 output DP-3
workspace $ws3 output DP-1
workspace $ws4 output DP-1

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# Reload/exit
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit Sway?' -B 'Yes' 'swaymsg exit'

# Resize mode
mode "resize" {
    bindsym h resize shrink width 10 px
    bindsym j resize grow height 10 px
    bindsym k resize shrink height 10 px
    bindsym l resize grow width 10 px

    bindsym Left resize shrink width 10 px
    bindsym Down resize grow height 10 px
    bindsym Up resize shrink height 10 px
    bindsym Right resize grow width 10 px

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# ============ SCREENSHOTS ============
# Full screen to file
bindsym Print exec grim ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png

# Select region to file
bindsym Shift+Print exec grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%Y%m%d-%H%M%S).png

# Full screen to clipboard
bindsym Ctrl+Print exec grim - | wl-copy

# Select region to clipboard
bindsym Ctrl+Shift+Print exec grim -g "$(slurp)" - | wl-copy

# Status bar
bar {
    status_command i3blocks
}

# System overlay (replaces conky)
exec_always pkill -f "waybar.*config-overlay" || true; sleep 0.2; waybar -c ~/.config/waybar/config-overlay -s ~/.config/waybar/style-overlay.css &
