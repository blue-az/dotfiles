# skhd keybindings - sway/i3 style
# cmd = mod key (Caps Lock on your keyboard)

# Focus windows (mod + hjkl)
cmd - h : yabai -m window --focus west
cmd - j : yabai -m window --focus south
cmd - k : yabai -m window --focus north
cmd - l : yabai -m window --focus east

# Move windows (mod + shift + hjkl)
shift + cmd - h : yabai -m window --swap west
shift + cmd - j : yabai -m window --swap south
shift + cmd - k : yabai -m window --swap north
shift + cmd - l : yabai -m window --swap east

# Resize windows (mod + ctrl + hjkl)
ctrl + cmd - h : yabai -m window --resize left:-50:0; yabai -m window --resize right:-50:0
ctrl + cmd - j : yabai -m window --resize bottom:0:50; yabai -m window --resize top:0:50
ctrl + cmd - k : yabai -m window --resize top:0:-50; yabai -m window --resize bottom:0:-50
ctrl + cmd - l : yabai -m window --resize right:50:0; yabai -m window --resize left:50:0

# Toggle window float (mod + shift + space)
shift + cmd - space : yabai -m window --toggle float

# Toggle fullscreen (mod + f)
cmd - f : yabai -m window --toggle zoom-fullscreen

# Switch spaces/desktops (mod + number)
cmd - 1 : yabai -m space --focus 1
cmd - 2 : yabai -m space --focus 2
cmd - 3 : yabai -m space --focus 3
cmd - 4 : yabai -m space --focus 4
cmd - 5 : yabai -m space --focus 5

# Move window to space (mod + shift + number)
shift + cmd - 1 : yabai -m window --space 1
shift + cmd - 2 : yabai -m window --space 2
shift + cmd - 3 : yabai -m window --space 3
shift + cmd - 4 : yabai -m window --space 4
shift + cmd - 5 : yabai -m window --space 5

# Toggle split direction (mod + e)
cmd - e : yabai -m window --toggle split

# Balance windows (mod + =)
cmd - 0x18 : yabai -m space --balance

# Close window (mod + shift + q)
shift + cmd - q : yabai -m window --close

# Open terminal (mod + return)
cmd - return : open -na "Terminal"

# Restart yabai (mod + shift + r)
shift + cmd - r : yabai --restart-service
